# ============================================================
# EvoNexus Dashboard — Multi-stage Dockerfile
# Stage 1: Build React frontend
# Stage 2: Python backend (Flask) serving built frontend
# ============================================================

# --- Stage 1: Frontend build ---
FROM node:22-alpine AS frontend-build

WORKDIR /frontend
COPY dashboard/frontend/package.json dashboard/frontend/package-lock.json* ./
RUN npm install
COPY dashboard/frontend/ ./
RUN npm run build

# --- Stage 1b: Terminal-server build ---
FROM node:22-alpine AS terminal-build

RUN apk add --no-cache python3 make g++

WORKDIR /terminal
COPY dashboard/terminal-server/package.json dashboard/terminal-server/package-lock.json* ./
RUN npm install --omit=dev
COPY dashboard/terminal-server/ ./

# --- Stage 2: Python backend ---
FROM python:3.12-slim AS runtime

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Timezone
ENV TZ=America/Sao_Paulo
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

WORKDIR /workspace

# Install Python deps
COPY pyproject.toml uv.lock ./
RUN uv venv .venv && uv sync --no-dev

# Copy backend code
COPY dashboard/backend/ dashboard/backend/
COPY social-auth/ social-auth/
COPY scheduler.py ./

# Copy agents, skills, commands and config
COPY .claude/ .claude/
COPY config/ config/
COPY memory/ memory/

# Copy built frontend from stage 1
COPY --from=frontend-build /frontend/dist dashboard/frontend/dist

# Copy terminal-server from stage 1b
COPY --from=terminal-build /terminal dashboard/terminal-server/

# Create data directory for SQLite
RUN mkdir -p dashboard/data

# Startup script: launches terminal-server in background, then Flask
RUN printf '#!/bin/sh\nnode /workspace/dashboard/terminal-server/bin/server.js &\nexec uv run python dashboard/backend/app.py\n' > /workspace/start.sh \
    && chmod +x /workspace/start.sh

# Default port
ENV EVONEXUS_PORT=8080
EXPOSE 8080
EXPOSE 32352

CMD ["/workspace/start.sh"]
